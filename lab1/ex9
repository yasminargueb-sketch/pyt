while True:
    try:
        N = int(input("Enter an integer strictly greater than 2: "))
        if N >2 : break
        
    except: continue
for i in range(2, N+1):
    
    if N % i == 0:
        for j in range(2, (i // 2) + 1):
            if i % j == 0:
                break
        else:
            print(i, end=" ")

print()  